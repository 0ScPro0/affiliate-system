# Project root
PROJECT_ROOT=C:\MIT\Web\affiliate-system

# Server configuration
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_SHUTDOWN_TIMEOUT=5000ms

# Database configuration
DATABASE_POSTGRES_HOST=localhost
DATABASE_POSTGRES_PORT=5432
DATABASE_POSTGRES_USER=affiliate
DATABASE_POSTGRES_PASSWORD=affiliate
DATABASE_POSTGRES_DB=affiliate
DATABASE_POSTGRES_URL=postgres://affiliate:affiliate@localhost:5432/affiliate?sslmode=disable
DATABASE_POSTGRES_TIMEOUT=5000ms

# Security configuration
SECURITY_SECRET_KEY=ultra-mega-very-secret-key
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=30

# Kafka configuration
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PARTNER=public_partner
KAFKA_TOPIC_CATEGORY=public_category
KAFKA_TOPIC_OFFER=public_offer
KAFKA_GROUP_ID=affiliate-service
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=3000
KAFKA_RETRY_BACKOFF_MS=1000
KAFKA_RECONNECT_BACKOFF_MS=1000

# Logger configuration
LOGGER_LEVEL=debug
LOGGER_FOLDER=./out/logs

# Environment configuration
ENVIRONMENT_DEBUG=True